{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri-conf.schema.json",
  "productName": "PerFi",
  "version": "0.1.0",
  "identifier": "com.perfi.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PerFi - Personal Finance",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
